    "1.邻接矩阵\n",
    "\n",
    "       A  B  C  D  E  F\n",
    "    A  0  1  1  0  0  0\n",
    "    B  1  0  0  0  1  0\n",
    "    C  1  0  0  0  0  1\n",
    "    D  0  0  0  0  1  1\n",
    "    E  0  1  0  1  0  0\n",
    "    F  0  0  1  1  0  0\n",
    "\n",
    "1代表顶点间有边，0代表顶点间无边\n"
   ],
